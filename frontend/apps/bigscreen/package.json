{
  "name": "bigscreen",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@edu/api": "workspace:*",
    "@tanstack/react-query": "^5.45.0",
    "echarts": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.6.0",
    "globals": "^15.15.0",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.3.3",
    "vitest": "^2.0.3"
  }
}
